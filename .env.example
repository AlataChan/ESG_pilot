# ESG Pilot - Environment Configuration
# Copy this file to .env and fill in your actual values

# ========================================
# Application Environment
# ========================================
# Options: 'docker', 'local', 'test'
ENV_STATE=local

# ========================================
# Database Configuration (PostgreSQL)
# ========================================
# For Docker deployment
DB_USER=esg_user
DB_PASSWORD=esg_password
DB_HOST=db
DB_PORT=5432
DB_NAME=esg_db

# For local development with SQLite (leave blank to use SQLite)
# SQLITE_DB_PATH=esg_copilot_dev.db

# ========================================
# AI/LLM Configuration
# ========================================

# DeepSeek API (Required for main LLM functionality)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-reasoner

# OpenAI API (Required for embeddings)
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL_NAME=text-embedding-3-large
EMBEDDING_DIM=3072

# ========================================
# Vector Store Configuration (ChromaDB)
# ========================================
# For Docker deployment
CHROMA_DB_HOST=chroma
CHROMA_DB_PORT=8000

# For local development
# CHROMA_DB_PATH=chroma_db_data

CHROMA_COLLECTION_NAME=esg_collection

# ========================================
# Application Settings
# ========================================
PROJECT_NAME=ESG-Copilot
PROJECT_VERSION=1.0.0
API_V1_STR=/api/v1

# ========================================
# Security & CORS
# ========================================
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ========================================
# JWT Authentication (✅ Week 1 Day 2-3)
# ========================================
# ⚠️ CRITICAL: Change this to a random secret key in production!
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========================================
# Optional: Advanced Configuration
# ========================================
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Request timeout (seconds)
REQUEST_TIMEOUT=180

# Max retries for API calls
MAX_RETRIES=3

# ========================================
# Docker-specific Variables
# ========================================
# These are used only when running in Docker
POSTGRES_USER=esg_user
POSTGRES_PASSWORD=esg_password
POSTGRES_DB=esg_db

# ========================================
# IMPORTANT NOTES:
# ========================================
# 1. Never commit your actual .env file to version control!
# 2. DeepSeek and OpenAI API keys are REQUIRED for the system to function
# 3. For local development, use ENV_STATE=local to use SQLite + local ChromaDB
# 4. For Docker deployment, use ENV_STATE=docker and set all DB_* variables
# 5. Get DeepSeek API key from: https://platform.deepseek.com/
# 6. Get OpenAI API key from: https://platform.openai.com/
