# ESG Pilot - Environment Configuration
# Copy this file to .env and fill in your actual values

# ========================================
# Application Environment
# ========================================
# Options: 'docker', 'local', 'test'
ENV_STATE=local

# ========================================
# Database Configuration (PostgreSQL / SQLite)
# ========================================
# Docker / PostgreSQL settings
DB_USER=esg_user
DB_PASSWORD=esg_password
DB_HOST=db
DB_PORT=5432
DB_NAME=esg_db

# Local SQLite settings
SQLITE_DB_PATH=./esg_copilot_dev.db

# ========================================
# AI / LLM Configuration
# ========================================

# DeepSeek API (Required for main LLM functionality)
# Get key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-reasoner

# Embedding API (DashScope / Qwen3, OpenAI-compatible)
# Get key from: https://bailian.console.aliyun.com
EMBEDDING_API_KEY=your_dashscope_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_DIM=1024

# ========================================
# Vector Store Configuration (ChromaDB)
# ========================================
# Docker deployment
CHROMA_DB_HOST=chroma
CHROMA_DB_PORT=8000

# Local development persistence path
CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_COLLECTION_NAME=esg_collection

# ========================================
# Application Settings
# ========================================
PROJECT_NAME=ESG-Copilot
PROJECT_VERSION=1.0.0
API_V1_STR=/api/v1

# ========================================
# Security & CORS
# ========================================
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]

# ========================================
# JWT Authentication (Week 1 Day 2-3)
# ========================================
# Required in production. Fill this with a random secret before deployment.
# Generate with: openssl rand -hex 32
SECRET_KEY=your_random_32_char_secret_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========================================
# Optional: Advanced Configuration
# ========================================
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Request timeout (seconds)
REQUEST_TIMEOUT=180

# Max retries for API calls
MAX_RETRIES=3

# ========================================
# Docker-specific Variables
# ========================================
# These are used only when running in Docker
POSTGRES_USER=esg_user
POSTGRES_PASSWORD=esg_password
POSTGRES_DB=esg_db

# ========================================
# IMPORTANT NOTES
# ========================================
# 1. Do not store real secrets in version control.
# 2. DeepSeek and DashScope API keys are required for live model calls.
# 3. For local development, use ENV_STATE=local to use SQLite + local ChromaDB.
# 4. For Docker deployment, use ENV_STATE=docker and set all DB_* variables.
