# Local Development Environment Variables

# --- For a fully local setup, we don't define DB_HOST or CHROMA_HOST ---
# config.py will automatically fall back to SQLite and local Chroma persistence.

# SQLite database file path (relative to the project root)
SQLITE_DB_PATH=./esg_copilot_dev.db

# ChromaDB local persistence path (relative to the project root)
CHROMA_PERSIST_DIRECTORY=./chroma_data

# --- Embedding Configuration (DashScope / Qwen3) ---
# Get key at: https://bailian.console.aliyun.com
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_DIM=1024
